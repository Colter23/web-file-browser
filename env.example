# 首次启动时用于初始化单管理员密码；配置文件已有密码哈希后不会覆盖。
WEB_FILE_BROWSER_ADMIN_PASSWORD=change-me-before-first-start

# 容器内进程使用的 UID/GID。建议填宿主机拥有挂载目录的用户。
WEB_FILE_BROWSER_UID=1000
WEB_FILE_BROWSER_GID=1000

# 宿主机暴露端口。
WEB_FILE_BROWSER_PORT=8080

# 默认空值表示只允许同源访问；跨域开发时写具体来源，逗号分隔，不支持 *。
WEB_FILE_BROWSER_CORS_ORIGINS=

# 仅在服务只通过可信反向代理访问时启用，用于读取 X-Forwarded-For。
WEB_FILE_BROWSER_TRUST_PROXY_HEADERS=false

# 常用运行配置。
WEB_FILE_BROWSER_CONFLICT_POLICY=autoRename
WEB_FILE_BROWSER_MAX_UPLOAD_BYTES=
WEB_FILE_BROWSER_MAX_EDIT_BYTES=2097152
WEB_FILE_BROWSER_EDITABLE_EXTENSIONS=
WEB_FILE_BROWSER_EDITABLE_MIME_TYPES=
WEB_FILE_BROWSER_MAX_DIR_PAGE_SIZE=2000
WEB_FILE_BROWSER_TASK_HISTORY_LIMIT=200
WEB_FILE_BROWSER_AUDIT_MAX_BYTES=10485760
WEB_FILE_BROWSER_AUDIT_RETENTION_FILES=8
WEB_FILE_BROWSER_MAX_EXTRACT_BYTES=
WEB_FILE_BROWSER_MAX_EXTRACT_FILES=
WEB_FILE_BROWSER_MAX_EXTRACT_DEPTH=64
WEB_FILE_BROWSER_INDEX_ENABLED=false
WEB_FILE_BROWSER_INDEX_REBUILD_ON_STARTUP=false
